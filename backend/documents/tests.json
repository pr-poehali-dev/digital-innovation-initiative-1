{
  "tests": [
    {
      "name": "Upload requires auth",
      "method": "POST",
      "path": "/",
      "body": {"project_id": 1, "filename": "test.pdf", "file_data": "", "file_type": "pdf"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "REGRESSION: document.get_url чужой документ → 403",
      "method": "POST",
      "path": "/",
      "headers": {"X-Session-Id": "regression_test_session_userb_isolation_check_64hexchar000000aaa"},
      "body": {"action": "document.get_url", "document_id": 1},
      "expectedStatus": 403,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "REGRESSION: document.delete чужой документ → 403",
      "method": "POST",
      "path": "/",
      "headers": {"X-Session-Id": "regression_test_session_userb_isolation_check_64hexchar000000aaa"},
      "body": {"action": "document.delete", "document_id": 1},
      "expectedStatus": 403,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "REGRESSION: document.rename чужой документ → 403",
      "method": "POST",
      "path": "/",
      "headers": {"X-Session-Id": "regression_test_session_userb_isolation_check_64hexchar000000aaa"},
      "body": {"action": "document.rename", "document_id": 1, "new_name": "hacked.pdf"},
      "expectedStatus": 403,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}
