{
  "tests": [
    {
      "name": "project.list requires auth",
      "method": "POST",
      "path": "/",
      "body": {"action": "project.list"},
      "expectedStatus": 401,
      "expectedBody": {"ok": false},
      "bodyMatcher": "partial"
    },
    {
      "name": "unknown action returns 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "fake.action"},
      "expectedStatus": 400,
      "expectedBody": {"ok": false},
      "bodyMatcher": "partial"
    },
    {
      "name": "missing action returns 400",
      "method": "POST",
      "path": "/",
      "body": {},
      "expectedStatus": 400,
      "expectedBody": {"ok": false},
      "bodyMatcher": "partial"
    },
    {
      "name": "REGRESSION: project.get чужой проект → 403",
      "method": "POST",
      "path": "/",
      "headers": {"X-Session-Id": "regression_test_session_userb_isolation_check_64hexchar000000aaa"},
      "body": {"action": "project.get", "project_id": 1},
      "expectedStatus": 403,
      "expectedBody": {"ok": false},
      "bodyMatcher": "partial"
    },
    {
      "name": "REGRESSION: project.invite чужой проект → 403",
      "method": "POST",
      "path": "/",
      "headers": {"X-Session-Id": "regression_test_session_userb_isolation_check_64hexchar000000aaa"},
      "body": {"action": "project.invite", "project_id": 1, "email": "hacker@test.com"},
      "expectedStatus": 403,
      "expectedBody": {"ok": false},
      "bodyMatcher": "partial"
    },
    {
      "name": "REGRESSION: project.archive чужой проект → 403",
      "method": "POST",
      "path": "/",
      "headers": {"X-Session-Id": "regression_test_session_userb_isolation_check_64hexchar000000aaa"},
      "body": {"action": "project.archive", "project_id": 1},
      "expectedStatus": 403,
      "expectedBody": {"ok": false},
      "bodyMatcher": "partial"
    },
    {
      "name": "REGRESSION: project.restore чужой проект → 403",
      "method": "POST",
      "path": "/",
      "headers": {"X-Session-Id": "regression_test_session_userb_isolation_check_64hexchar000000aaa"},
      "body": {"action": "project.restore", "project_id": 1},
      "expectedStatus": 403,
      "expectedBody": {"ok": false},
      "bodyMatcher": "partial"
    },
    {
      "name": "project.set_workspace_mode requires auth",
      "method": "POST",
      "path": "/",
      "body": {"action": "project.set_workspace_mode", "project_id": 1, "workspace_mode": "polygon"},
      "expectedStatus": 401,
      "expectedBody": {"ok": false},
      "bodyMatcher": "partial"
    },
    {
      "name": "REGRESSION: project.set_workspace_mode чужой проект → 403",
      "method": "POST",
      "path": "/",
      "headers": {"X-Session-Id": "regression_test_session_userb_isolation_check_64hexchar000000aaa"},
      "body": {"action": "project.set_workspace_mode", "project_id": 1, "workspace_mode": "polygon"},
      "expectedStatus": 403,
      "expectedBody": {"ok": false},
      "bodyMatcher": "partial"
    }
  ]
