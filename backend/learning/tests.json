{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Unauthorized - goals",
      "method": "GET",
      "path": "/?action=goals",
      "expectedStatus": 401,
      "expectedBody": {"ok": false},
      "bodyMatcher": "partial"
    },
    {
      "name": "Unauthorized - progress",
      "method": "GET",
      "path": "/?action=progress&goal_id=1",
      "expectedStatus": 401,
      "expectedBody": {"ok": false},
      "bodyMatcher": "partial"
    },
    {
      "name": "Unauthorized - checkins",
      "method": "GET",
      "path": "/?action=checkins&goal_id=1",
      "expectedStatus": 401,
      "expectedBody": {"ok": false},
      "bodyMatcher": "partial"
    },
    {
      "name": "Unauthorized - topic_learn",
      "method": "POST",
      "path": "/?action=topic_learn",
      "body": {"topic_title": "Тест", "mode": "full"},
      "expectedStatus": 401,
      "expectedBody": {"ok": false},
      "bodyMatcher": "partial"
    }
  ]
}