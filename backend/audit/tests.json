{
  "tests": [
    {
      "name": "audit.prepare_upload требует авторизации",
      "method": "POST",
      "path": "/",
      "body": {"action": "audit.prepare_upload", "project_id": 1, "filename": "test.pptx", "size_bytes": 1000},
      "expectedStatus": 401,
      "expectedBody": {"ok": false},
      "bodyMatcher": "partial"
    },
    {
      "name": "audit.run требует авторизации",
      "method": "POST",
      "path": "/",
      "body": {"action": "audit.run", "project_id": 1, "upload_id": "upl_test"},
      "expectedStatus": 401,
      "expectedBody": {"ok": false},
      "bodyMatcher": "partial"
    },
    {
      "name": "audit.get без авторизации → 401",
      "method": "POST",
      "path": "/",
      "body": {"action": "audit.get", "audit_id": 1},
      "expectedStatus": 401,
      "expectedBody": {"ok": false},
      "bodyMatcher": "partial"
    },
    {
      "name": "audit.list без авторизации → 401",
      "method": "POST",
      "path": "/",
      "body": {"action": "audit.list", "project_id": 1},
      "expectedStatus": 401,
      "expectedBody": {"ok": false},
      "bodyMatcher": "partial"
    }
  ]
}