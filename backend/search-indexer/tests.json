{
  "tests": [
    {
      "name": "Без токена — 403",
      "method": "POST",
      "path": "/?action=index_all",
      "expectedStatus": 403,
      "expectedBody": {"error": "forbidden"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Неверный токен — 403",
      "method": "POST",
      "path": "/?action=index_all",
      "headers": {"X-Internal-Token": "wrong_token_xxxxxx"},
      "expectedStatus": 403,
      "expectedBody": {"error": "forbidden"},
      "bodyMatcher": "partial"
    },
    {
      "name": "delete_project_cascade без токена — 403",
      "method": "POST",
      "path": "/?action=delete_project_cascade",
      "body": {"project_id": 999},
      "expectedStatus": 403,
      "expectedBody": {"error": "forbidden"},
      "bodyMatcher": "partial"
    },
    {
      "name": "OPTIONS без токена — 200 (CORS preflight)",
      "method": "OPTIONS",
      "path": "/?action=index_all",
      "expectedStatus": 200,
      "bodyMatcher": "partial"
    }
  ]
}
