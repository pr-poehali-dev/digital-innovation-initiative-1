{
  "tests": [
    {
      "name": "Без токена — 403",
      "method": "POST",
      "path": "/?action=index_all",
      "expectedStatus": 403,
      "expectedBody": {"error": "forbidden"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Неверный токен — 403",
      "method": "POST",
      "path": "/?action=index_all",
      "headers": {"X-Internal-Token": "wrong_token_xxxxxx"},
      "expectedStatus": 403,
      "expectedBody": {"error": "forbidden"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Неизвестное действие без токена — 403",
      "method": "POST",
      "path": "/?action=unknown",
      "expectedStatus": 403,
      "expectedBody": {"error": "forbidden"},
      "bodyMatcher": "partial"
    }
  ]
}
