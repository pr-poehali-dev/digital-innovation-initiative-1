{
  "tests": [
    {
      "name": "Generate without auth returns 401",
      "method": "POST",
      "path": "/",
      "body": {"task_id": 1},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "REGRESSION: get_run чужой юзер не видит результат → 403",
      "method": "POST",
      "path": "/",
      "headers": {"X-Session-Id": "regression_test_session_userb_isolation_check_64hexchar000000aaa"},
      "body": {"action": "get_run", "run_id": 2},
      "expectedStatus": 403,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "render_visual без авторизации → 401",
      "method": "POST",
      "path": "/",
      "body": {"action": "render_visual", "run_id": 1, "slide_index": 1},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "REGRESSION: render_visual чужой run → 403",
      "method": "POST",
      "path": "/",
      "headers": {"X-Session-Id": "regression_test_session_userb_isolation_check_64hexchar000000aaa"},
      "body": {"action": "render_visual", "run_id": 2, "slide_index": 1},
      "expectedStatus": 403,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}
